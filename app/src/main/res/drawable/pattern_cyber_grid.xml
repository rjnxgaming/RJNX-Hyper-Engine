<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle"
    android:tileMode="repeat">
    
    <size
        android:width="40dp"
        android:height="40dp" />
    
    <stroke
        android:width="1dp"
        android:color="@color/cyber_pink"
        android:dashWidth="2dp"
        android:dashGap="2dp" />
    
    <stroke
        android:width="1dp"
        android:color="@color/cyber_blue"
        android:dashWidth="2dp"
        android:dashGap="2dp"
        android:startX="20dp"
        android:startY="0dp"
        android:endX="20dp"
        android:endY="40dp" />
</shape>
